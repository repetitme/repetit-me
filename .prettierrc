{
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "bracketSpacing": true,
  "trailingComma": "none",
  "printWidth": 80,
  "tabWidth": 2,
  "arrowParens": "always",
  "endOfLine": "auto",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react$",
    "^[a-zA-Z]",
    "^@(?!/)",
    "^[./](?!.*\\.scss|.*type(s)?$)",
    "^.+\\.scss$",
    "^.*type(s)?$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
